# Gemini API key — used by the Python scraper (curadoria + extração de blogs sem RSS)
GEMINI_API_KEY=your_key_here

# Reddit API oficial (OAuth app-only). Crie um app "script" em
# https://www.reddit.com/prefs/apps → copie o client id (sob o nome do app) e o secret.
# Sem isto, o scraper cai no fallback Crawl4AI (frágil).
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Absolute path to the SQLite DB file
DB_PATH=/absolute/path/to/creative-ai-feed/db/feed.db

# Path to the scraper directory (used by Next.js /api/run to call subprocess)
SCRAPER_DIR=/absolute/path/to/creative-ai-feed/scraper
